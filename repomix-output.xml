      {corners.map((pos, i) => (
        <span
          key={i}
          style={{
            position: 'absolute',
            width: 6,
            height: 6,
            background: color,
            display: 'block',
            ...pos,
          }}
        />
      ))}
      {children}
    </div>
  )
}
